# ----------------------------------------------------------------------------
# Marp Player — environment template
# Copy this file to `.env` and fill in the values for your deployment.
# ----------------------------------------------------------------------------

# --- Required ----------------------------------------------------------------
# PostgreSQL connection string. Any hosted or self-hosted Postgres works.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?connect_timeout=15"

# --- Optional: PDF export + LLM-assisted features ----------------------------
# Abacus.AI API key used by /api/export-pdf and /api/v1/render-pdf to convert
# HTML into a PDF through the HTML2PDF gateway.
ABACUSAI_API_KEY=""

# --- Optional: social-support gate in the MCP modal --------------------------
# Shown in the MCP modal before a user can generate an API key.
LINKEDIN_PERS_URL="https://www.linkedin.com/in/your-handle/"
GITHUB_CURRENT_REPO="https://github.com/your-org/your-fork"

# --- Optional: legacy static API keys ---------------------------------------
# Comma-separated Bearer tokens. New deployments should prefer the in-app
# "Generate API Key" flow instead of this env var.
# MARP_API_KEYS="key1,key2,key3"

# --- Optional: CI mirror to GitHub -------------------------------------------
# Used by .github/workflows/push-to-github.yml when you trigger the mirror
# workflow manually.
# GITHUB_TOKEN=""
